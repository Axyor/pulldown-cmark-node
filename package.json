{
  "name": "@Axyor/pulldown-cmark-node",
  "version": "1.2.1",
  "description": "Blazingly fast Markdown to HTML renderer for Node.js using Rust's pulldown-cmark.",
  "main": "index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axyor/pulldown-cmark-node.git"
  },
  "license": "MIT",
  "keywords": [
    "markdown",
    "parser",
    "rust",
    "napi-rs",
    "performance"
  ],
  "files": [
    "index.d.ts",
    "index.js",
    "src",
    "Cargo.toml"
  ],
  "napi": {
    "binaryName": "pulldown-cmark-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "files": [
      "__test__/*.spec.ts"
    ]
  },
  "devDependencies": {
    "@ava/typescript": "^5.0.0",
    "@napi-rs/cli": "^3.0.0",
    "ava": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
